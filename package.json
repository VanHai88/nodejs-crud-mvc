{
  "name": "nodejs-mvc-crud",
  "version": "1.0.0",
  "description": "Node.js MVC project with Express, TypeScript, and JSON Server for CRUD operations",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node src/server.ts",
    "json-server": "json-server --watch db.json --port 3001",
    "dev:all": "concurrently \"npm run dev\" \"npm run json-server\""
  },
  "keywords": ["nodejs", "express", "typescript", "mvc", "crud", "json-server"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.6.2",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "json-server": "^0.17.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.5",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "concurrently": "^8.2.2",
    "dotenv": "^16.3.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.3"
  }
}